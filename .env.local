NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Website Builder — root domain for subdomain routing (e.g. "medbook.ai")
# Leave empty in development; subdomains won't work locally anyway
# In production set to your domain: NEXT_PUBLIC_ROOT_DOMAIN=medbook.ai
NEXT_PUBLIC_ROOT_DOMAIN=

# Email Configuration (Resend)
RESEND_API_KEY=
NEXT_PUBLIC_EMAIL_FROM=onboarding@resend.dev
# In test mode, all emails go to this address (Resend free tier restriction)
# Remove this line once you verify a domain at resend.com/domains
RESEND_DEV_EMAIL=

# Crypto Payment Configuration (Polygon Network)
NEXT_PUBLIC_CRYPTO_WALLET_ADDRESS=
NEXT_PUBLIC_CRYPTO_USDC_CONTRACT=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
NEXT_PUBLIC_CRYPTO_NETWORK=Polygon
NEXT_PUBLIC_CRYPTO_CHAIN_ID=137

# Plan Prices in USDC
NEXT_PUBLIC_PLAN_STARTER_PRICE=49
NEXT_PUBLIC_PLAN_PROFESSIONAL_PRICE=99
NEXT_PUBLIC_PLAN_ENTERPRISE_PRICE=299

# Website Hosting Fee (USDC/month)
NEXT_PUBLIC_WEBSITE_HOSTING_PRICE=1
